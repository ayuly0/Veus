# Veus Project - Environment Configuration
# Copy this file to '.env' and fill in your credentials securely.

# Discord API Token (Bot or User)
# DISCORD_TOKEN=MTE4M...

# Toggle for bot account (true/false)
DISCORD_IS_BOT=false

# SSL Verification (true/false)
# Highly recommended to keep true unless debugging
SSL_VERIFY=true

# Custom Scripts Directory
SCRIPTS_DIR=scripts
